[Unit]
Description=AgentHub Backend API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/agenthub/backend
ExecStart=/opt/agenthub/venv/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
